# ── Telegram ────────────────────────────────────────────────
# Get this from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Public HTTPS URL where Telegram will POST updates (webhook mode).
# Leave blank if you only run in --polling mode locally.
# Example: https://your-app.up.railway.app
WEBHOOK_URL=

# A random secret string. Telegram echoes it back in the
# X-Telegram-Bot-Api-Secret-Token header so you can verify requests.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Bot behaviour ───────────────────────────────────────────
# Username WITHOUT the @, used to detect mentions in groups.
BOT_USERNAME=GrantBekBot

# Comma-separated chat IDs of discussion groups the bot may reply in.
# Leave blank to allow all groups it's a member of.
ALLOWED_GROUP_IDS=

# ── Storage / misc ──────────────────────────────────────────
DATABASE_PATH=grantbek.db
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=en

# ── Claude API (optional) ───────────────────────────────────
# If set, GrantBek uses Claude to phrase bilingual answers grounded in your
# grant DB. If left blank, it falls back to free keyword-only FAQ matching.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=600

# Footer handle shown at the bottom of every grant post.
CHANNEL_HANDLE=@EduGrandsUz

# Auto-reply to every comment under a recognised grant post (true), or only
# when the bot is @mentioned/replied to (false).
GROUP_AUTO_REPLY=true
